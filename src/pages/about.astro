---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import Content2 from "@/components/widgets/Content2.astro";
import Values from "@/components/widgets/Values.astro";
import aboutImage from "@/assets/images/about-office.webp";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const metadata = {
  title: "Sobre la consultoría",
  description:
    "Conoce el enfoque, visión y principios detrás de esta consultoría de optimización de campañas en Amazon.",
};

const values = [
  {
    title: "Enfoque en resultados",
    description:
      "Cada recomendación busca mejorar desempeño real: visibilidad, conversión, eficiencia publicitaria y crecimiento sostenible.",
  },
  {
    title: "Decisiones basadas en datos",
    description:
      "La optimización no se hace por intuición. Analizamos términos de búsqueda, estructura de campañas, métricas y contexto competitivo.",
  },
  {
    title: "Claridad estratégica",
    description:
      "Buscamos que cada campaña tenga una función clara dentro de la cuenta: descubrimiento, control, validación o escalamiento.",
  },
  {
    title: "Transparencia",
    description:
      "Explicamos qué se está haciendo, por qué se hace y qué impacto se espera, para que el cliente entienda el proceso.",
  },
  {
    title: "Mejora continua",
    description:
      "Amazon Ads no es una configuración de una sola vez. El trabajo real está en revisar datos, iterar y ajustar con disciplina.",
  },
  {
    title: "Visión integral",
    description:
      "No vemos las campañas de forma aislada. También consideramos listing, keywords, competencia y potencial de conversión.",
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />

  <Content2
    title="Una consultoría pensada para crecer en Amazon con más control y menos improvisación"
    description={[
      "Este proyecto nace de una idea simple: muchas marcas y vendedores invierten en Amazon Ads sin una estructura clara, sin un proceso consistente de análisis y sin una estrategia real para convertir datos en decisiones. El resultado suele ser presupuesto desperdiciado, campañas desordenadas y muy poca claridad sobre qué está funcionando de verdad.",
      "La consultoría está enfocada en ayudar a ordenar esa operación publicitaria. Desde la investigación de keywords y la optimización del listing, hasta la estructura de campañas y el análisis de desempeño, el objetivo es construir una base más sólida para crecer de forma rentable dentro de Amazon.",
    ]}
    tagline="Sobre el proyecto"
    image={aboutImage}
    imageAlt="Consultoría de optimización de campañas en Amazon"
    actions={[
      {
        text: "Contactar",
        href: `${baseUrl}contact`,
        variant: "primary",
        icon: "lucide:mail",
      },
      {
        text: "Ver servicios",
        href: `${baseUrl}services`,
        variant: "secondary",
        icon: "lucide:arrow-right",
      },
    ]}
  />

  <Values
    items={values}
    columns={3}
    tagline="Principios"
    title="Lo que define nuestra forma de trabajar"
    subtitle="Un enfoque práctico, analítico y orientado a crecimiento rentable"
  />
</BaseLayout>
