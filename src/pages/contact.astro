---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Features from "@/components/widgets/Features.astro";
import Content from "@/components/widgets/Content.astro";
import Form from "@/components/ui/Form.astro";

const metadata = {
  title: "Contacto",
  description:
    "Agenda una conversación para revisar tus campañas de Amazon y detectar oportunidades de mejora.",
};

const visionText = [
  "Si vendes en Amazon y quieres mejorar el rendimiento de tus campañas publicitarias, puedes contactarme para revisar tu caso y explorar posibles optimizaciones.",
];
---

<BaseLayout {metadata}>
  <Content
    tagline="Contacto"
    title="Hablemos sobre tus campañas en Amazon"
    description={visionText}
  />

  <div
    class="reveal mx-auto max-w-xl bg-card border border-border rounded-3xl p-8 shadow-sm mb-12 md:mb-16"
  >
    <Form />
  </div>

  <Features
    tagline="Contacto"
    title="Cómo podemos empezar a trabajar"
    subtitle="Puedes escribir para hacer preguntas, solicitar una auditoría de campañas o conversar sobre cómo mejorar el rendimiento de tu cuenta publicitaria en Amazon."
    classes={{ container: "pt-0 md:pt-0" }}
    features={[
      {
        title: "Llamada inicial",
        description:
          "Podemos agendar una breve llamada para entender tu producto, mercado y situación actual en Amazon Ads.",
        icon: "lucide:phone",
        iconClass: "bg-green-500/10 text-green-400",
      },
      {
        title: "Email",
        description:
          "Puedes enviar información sobre tu producto o cuenta para revisar el contexto antes de hablar.",
        icon: "lucide:mail",
        iconClass: "bg-yellow-500/10 text-yellow-400",
      },
      {
        title: "Trabajo remoto",
        description:
          "La consultoría se realiza de forma remota y puede aplicarse a cuentas en distintos mercados de Amazon.",
        icon: "lucide:map-pin",
        iconClass: "bg-red-500/10 text-red-400",
      },
      {
        title: "Análisis de campañas",
        description:
          "Podemos revisar la estructura actual de tus campañas y detectar oportunidades de optimización.",
        icon: "lucide:user-check",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Resolución de dudas",
        description:
          "Si tienes preguntas sobre Amazon Ads, keywords o estructura de campañas, podemos revisarlas.",
        icon: "lucide:wrench",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Estrategia publicitaria",
        description:
          "Diseñamos una estrategia más clara para organizar campañas y escalar con datos.",
        icon: "lucide:briefcase",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />
</BaseLayout>
