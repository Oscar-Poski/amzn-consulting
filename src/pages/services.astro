---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceList from "@/components/widgets/ServiceList.astro";
import Content from "@/components/widgets/Content.astro";
import Content2 from "@/components/widgets/Content2.astro";
import webDevImg from "@/assets/images/services/web-dev.webp";
import seoImg from "@/assets/images/services/seo.webp";
import consultingImg from "@/assets/images/services/consulting.webp";

const services = [
  {
    title: "Auditoría de Amazon Ads",
    description:
      "Revisión de estructura de campañas, términos de búsqueda, targets, bids y uso del presupuesto.",
    icon: "lucide:search-check",
  },
  {
    title: "Optimización de campañas",
    description:
      "Ajustes sobre campañas automáticas y manuales para mejorar control, eficiencia y rendimiento.",
    icon: "lucide:sliders-horizontal",
  },
  {
    title: "Estrategia de crecimiento",
    description:
      "Construcción de una estructura publicitaria más clara y escalable para crecer con datos.",
    icon: "lucide:trending-up",
  },
];

const metadata = {
  title: "Servicios",
  description:
    "Descubre los servicios de consultoría para optimización de campañas en Amazon: auditoría, estructura, keywords y escalamiento.",
};
---

<BaseLayout {metadata}>
  <Content
    tagline="Servicios"
    title="Servicios de consultoría para Amazon Ads"
    description={[
      "Ayudamos a marcas y vendedores a estructurar, optimizar y escalar sus campañas en Amazon con un enfoque práctico, analítico y orientado a rentabilidad.",
    ]}
  />

  <ServiceList services={services} classes={{ container: "pt-0 md:pt-0" }} />

  <Content
    tagline="Auditoría"
    title="Diagnóstico de cuenta y campañas"
    description={[
      "El primer paso es entender qué está pasando realmente dentro de la cuenta publicitaria. Revisamos estructura, distribución de presupuesto, campañas activas, términos de búsqueda y señales de desperdicio para detectar oportunidades claras de mejora.",
    ]}
    classes={{ container: "pb-0 md:pb-0" }}
  />

  <Content2
    items={[
      {
        title: "Revisión de estructura",
        description:
          "Analizamos si la cuenta está organizada de forma útil para discovery, control y escalamiento.",
      },
      {
        title: "Detección de ineficiencias",
        description:
          "Identificamos keywords, targets o campañas que consumen inversión sin aportar resultados consistentes.",
      },
    ]}
    image={webDevImg}
    imageAlt="Auditoría de campañas en Amazon"
    classes={{ container: "pt-0 md:pt-0" }}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Auditoría de Amazon Ads
      </h3>
      Una auditoría bien hecha permite entender dónde se está perdiendo dinero, qué
      campañas necesitan rediseño y qué oportunidades existen para mejorar el desempeño
      general de la cuenta.
    </Fragment>
  </Content2>

  <Content2
    isReversed={true}
    items={[
      {
        title: "Curado de keywords",
        description:
          "Filtramos y priorizamos keywords con base en relevancia, intención de compra y señales de conversión.",
      },
      {
        title: "Optimización operativa",
        description:
          "Ajustamos campañas, match types, bids, negatives y segmentación para mejorar control y rendimiento.",
      },
    ]}
    image={seoImg}
    imageAlt="Optimización de keywords y campañas"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Optimización de campañas y keywords
      </h3>
      No se trata solo de activar anuncios. El trabajo está en ordenar campañas, interpretar
      datos de búsqueda y convertir esa información en ajustes que mejoren CTR, conversión
      y eficiencia publicitaria.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Escalamiento con datos",
        description:
          "Tomamos decisiones de crecimiento sobre términos, campañas y productos que ya demostraron potencial.",
      },
      {
        title: "Visión estratégica",
        description:
          "Buscamos construir una operación publicitaria más clara, medible y sostenible en el tiempo.",
      },
    ]}
    image={consultingImg}
    imageAlt="Estrategia de crecimiento en Amazon Ads"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Estrategia para crecimiento rentable
      </h3>
      El objetivo no es únicamente bajar costos. También buscamos crear una base más
      sólida para escalar campañas de forma ordenada, entendiendo qué funciona, qué
      no funciona y dónde conviene invertir más presupuesto.
    </Fragment>
  </Content2>
</BaseLayout>
